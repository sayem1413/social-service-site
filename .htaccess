# ================================================================
# Subaita Foundation — Production .htaccess
# Optimized for SEO, Performance & Security
# Apache / cPanel / Shared Hosting Ready
# ================================================================

# ------------------------------------------------
# Disable directory listing
# ------------------------------------------------
Options -Indexes

# ------------------------------------------------
# Default homepage
# ------------------------------------------------
DirectoryIndex index.html

# ------------------------------------------------
# Enable rewrite engine
# ------------------------------------------------
RewriteEngine On

# =================================================
# CANONICAL URL REDIRECTS
# =================================================

# ------------------------------------------------
# Force HTTPS
# ------------------------------------------------
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ------------------------------------------------
# Force NON-WWW
# www.example.com -> example.com
# ------------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ------------------------------------------------
# Redirect index pages to homepage
# /index or /index.html -> /
# ------------------------------------------------
RewriteRule ^index(\.html)?$ / [R=301,L,NC]

# ------------------------------------------------
# Remove trailing slash from non-directories
# /about/ -> /about
# ------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# =================================================
# REMOVE .html EXTENSION
# =================================================

# ------------------------------------------------
# Redirect /page.html -> /page
# ------------------------------------------------
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# ------------------------------------------------
# Internally serve .html files
# /about -> /about.html
# ------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/.]+)/?$ $1.html [L]

# =================================================
# CUSTOM ERROR PAGES
# =================================================
ErrorDocument 404 /404.html

# =================================================
# BLOCK ACCESS TO SENSITIVE FILES
# =================================================
<FilesMatch "^(\.htaccess|\.env|composer\.(json|lock)|package(-lock)?\.json|webpack\.config\.js)$">
    Require all denied
</FilesMatch>

# =================================================
# SECURITY HEADERS
# =================================================
<IfModule mod_headers.c>

    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Clickjacking protection
    Header always set X-Frame-Options "SAMEORIGIN"

    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Hide server-powered info
    Header unset X-Powered-By

    # Cache-Control for static assets
    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|svg|webp|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

</IfModule>

# =================================================
# BROWSER CACHING
# =================================================
<IfModule mod_expires.c>

    ExpiresActive On

    # HTML
    ExpiresByType text/html "access plus 1 hour"

    # CSS & JS
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"

    # Images
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/jpg "access plus 6 months"
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/gif "access plus 6 months"
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 6 months"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fonts
    ExpiresByType font/woff2 "access plus 1 year"

    # PDF
    ExpiresByType application/pdf "access plus 1 month"

</IfModule>

# =================================================
# GZIP COMPRESSION
# =================================================
<IfModule mod_deflate.c>

    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE image/svg+xml

</IfModule>

# =================================================
# LIGHT BOT PROTECTION
# (Avoid blocking legitimate tools)
# =================================================
<IfModule mod_rewrite.c>

    RewriteCond %{HTTP_USER_AGENT} (scrapbot|harvest|extract|miner) [NC]
    RewriteRule .* - [F,L]

</IfModule>

# =================================================
# DISABLE ETAGS
# =================================================
FileETag None

<IfModule mod_headers.c>
    Header unset ETag
</IfModule>